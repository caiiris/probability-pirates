{
  "name": "pascal",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Pascal — a mobile-first, learn-by-doing probability app for high school students.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit-feedback": "tsx scripts/audit-feedback.ts",
    "harvest:audit-wording": "tsx scripts/curriculum-harvest/audit-wording.ts",
    "harvest:generate-cl0001": "tsx scripts/curriculum-harvest/generate-cl0001-review.ts",
    "harvest:generate-runtime-cl0001": "tsx scripts/curriculum-harvest/generate-runtime-cl0001-review.ts",
    "harvest:generate-runtime-reviews": "tsx scripts/curriculum-harvest/generate-runtime-template-reviews.ts",
    "harvest:ingest": "tsx scripts/curriculum-harvest/ingest.ts",
    "harvest:validate": "tsx scripts/curriculum-harvest/validate.ts",
    "harvest:verify-creative": "tsx scripts/curriculum-harvest/verify-creative-hard.ts",
    "harvest:write-seed-bank": "tsx scripts/curriculum-harvest/write-verified-seed-bank.ts",
    "wager:validate": "tsx scripts/wager-validate.ts",
    "wager:deploy": "tsx scripts/wager-deploy.ts",
    "deploy:firebase": "firebase deploy --only firestore:rules,firestore:indexes,hosting",
    "deploy:vercel": "vercel deploy --prod --yes --force",
    "deploy": "npm run build && npm run deploy:firebase && npm run deploy:vercel",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.1",
    "eslint": "^9.17.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@sentry/react": "^10.60.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^10.14.1",
    "framer-motion": "^11.18.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
