VITE_FIREBASE_API_KEY=
# IMPORTANT: set this to the SAME domain the app is served from (the Firebase
# Hosting site, e.g. your-site.web.app), NOT the default <project>.firebaseapp.com.
# Google sign-in routes through <AUTH_DOMAIN>/__/auth/handler; if that differs
# from the serving origin, mobile browsers drop the OAuth state ("missing
# initial state"). The serving domain must also be listed as an Authorized
# redirect URI (<domain>/__/auth/handler) on the project's OAuth web client and
# in Firebase Auth → Settings → Authorized domains. See docs/deploy-checklist.md §3.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional. Required only to enable Firebase Analytics (GA4).
VITE_FIREBASE_MEASUREMENT_ID=
VITE_USE_EMULATOR=false
VITE_SENTRY_DSN=

# ── F2 AI hint ladder (client, build-time) ─────────────────────────────────────
# Master switch for the live AI hint feature. When not exactly "true", useAiHint
# short-circuits to authored fallback copy (no network call) — the app works
# fully with AI off. Set to "true" only once /api/hint is deployed + keyed.
VITE_AI_ENABLED=false
# Origin of the /api/hint function. Leave EMPTY when the function is same-origin
# (whole-app on Vercel). Set to a full origin (e.g. https://pascal-api.vercel.app)
# only if the function is hosted separately from the app.
VITE_AI_API_BASE=

# ── Server/dev-time only ────────────────────────────────────────────────────────
# Consumed by Node scripts (harvest:*) and the /api/hint serverless function via
# process.env. DO NOT prefix with VITE_ — that would bundle the secret into the
# client and expose it to every visitor. On Vercel, set these as Environment
# Variables (Project → Settings → Environment Variables), NOT in the bundle.
# Keep real values in .env.local (gitignored); never commit them.
OPENAI_API_KEY=
# OpenAI model the hint function calls (e.g. gpt-4o, gpt-4o-mini, or a 5.x model).
OPENAI_MODEL=
# Firebase project id used to verify the ID token audience in /api/hint.
# Must equal VITE_FIREBASE_PROJECT_ID (the real project id, not the hosting site).
FIREBASE_PROJECT_ID=
