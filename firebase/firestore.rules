rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // /users/{uid} — owner-only access (was: any auth user, leaked email
    // and other PII to all signed-in clients).
    // Updates restricted to the field allowlist that habitService and
    // userService actually write, so an adversarial client can't wipe
    // createdAt / username / email or invent arbitrary fields.
    // ------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.xp == 0
                    && request.resource.data.currentStreak == 0
                    && request.resource.data.bestStreak == 0
                    && request.resource.data.stepsCompleted == 0
                    && request.resource.data.lessonsCompleted == 0
                    && request.resource.data.displayUsername is string
                    && request.resource.data.displayUsername.size() <= 30
                    && request.resource.data.bio is string
                    && request.resource.data.bio.size() <= 200;

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly([
                         'xp', 'stepsCompleted',
                         'currentStreak', 'bestStreak', 'lastActiveDate',
                         'lessonsCompleted', 'milestonesReached',
                         'bio', 'avatarUrl',
                         'activityDates',
                         'achievements', 'weeklyXp', 'weekKey',
                         'coins', 'claimedChests', 'streakFreezes',
                         'avatarStyle', 'ownedAvatarStyles',
                         'profileFlair', 'ownedFlair',
                         // username changes (D16 reversed): both the lookup key
                         // and the display casing may be edited from the profile.
                         'username', 'displayUsername'
                       ])
                    && request.resource.data.bio.size() <= 200
                    && request.resource.data.displayUsername is string
                    && request.resource.data.displayUsername.size() <= 30
                    && request.resource.data.username is string
                    && request.resource.data.username == request.resource.data.username.lower();

      allow delete: if false;

      // spec-progress-persistence
      match /lessonProgress/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /stepAttempts/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.attemptNumber is int
                      && request.resource.data.attemptNumber >= 1
                      && request.resource.data.attemptNumber <= 10
                      && request.resource.data.xpAwarded is int
                      && request.resource.data.xpAwarded >= 0
                      && request.resource.data.xpAwarded <= 20
                      && request.resource.data.wasCorrect is bool;
        allow update, delete: if false;
      }

      // spec-wp-8 — Phase 2 practice subcollections, owner-only
      match /learnerModel/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // spec-spaced-review — owner-only spaced-retrieval schedule
      match /reviewSchedule/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /practiceState/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /practiceXp/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // notifications — owner-only read; any authenticated user may CREATE a
      // notification on someone else's account (that's how a follow drops a
      // "X started following you" inbox item without Cloud Functions).
      //
      // Shape is locked down: closed-set `type`, the sender must be the writer
      // (`fromUid == auth.uid`), the recipient cannot be the sender, and
      // `createdAt` must be the server clock. The owner may toggle `read` and
      // delete their own items; nobody else can update or delete.
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid != uid
                      && request.resource.data.fromUid == request.auth.uid
                      && request.resource.data.type in ['follow']
                      && request.resource.data.read == false
                      && request.resource.data.createdAt == request.time
                      && request.resource.data.fromUsername is string
                      && request.resource.data.fromUsername.size() <= 30
                      && request.resource.data.fromDisplayUsername is string
                      && request.resource.data.fromDisplayUsername.size() <= 30
                      && request.resource.data.keys().hasOnly(
                           ['type', 'fromUid', 'fromUsername', 'fromDisplayUsername', 'createdAt', 'read']
                         );
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // studyEvents — owner CRUD, title/notes length-capped.
      // `eventType` is a closed enum (see src/features/schedule/eventTypes.ts).
      // `time` is an optional 24-hour "HH:MM" string for tests/timed sessions.
      match /studyEvents/{eventId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() >= 1
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.date is string
                      && request.resource.data.completed is bool
                      && (!('eventType' in request.resource.data)
                          || request.resource.data.eventType in ['study', 'test', 'homework', 'other'])
                      && (!('time' in request.resource.data)
                          || (request.resource.data.time is string
                              && request.resource.data.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
                      && (!('notes' in request.resource.data)
                          || request.resource.data.notes.size() <= 1000);
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['title', 'date', 'eventType', 'time', 'lessonId', 'notes', 'completed']);
      }
    }

    // ------------------------------------------------------------------
    // /publicProfiles/{uid} — PII-free projection of /users/{uid}. Readable by
    // any signed-in user (powers search, public profiles, leaderboard); only
    // the owner may write their own. Validation is tolerant of partial merges
    // (gamification writes touch only a few fields) but hard-blocks `email`.
    // ------------------------------------------------------------------
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
                    && request.auth.uid == uid
                    && !('email' in request.resource.data)
                    && (!('xp' in request.resource.data)
                        || (request.resource.data.xp is int && request.resource.data.xp >= 0))
                    && (!('weeklyXp' in request.resource.data)
                        || request.resource.data.weeklyXp >= 0)
                    && (!('bio' in request.resource.data)
                        || request.resource.data.bio.size() <= 200);

      allow delete: if false;

      // Who this user follows. The list owner manages it.
      match /following/{followeeUid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
      }

      // Who follows this user. The FOLLOWER writes their own entry (doc id is
      // their uid), so following someone adds a row to their followers list.
      match /followers/{followerUid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerUid;
      }

      // Kudos/cheers. The SENDER writes their own entry (doc id is their uid).
      match /kudos/{fromUid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == fromUid;
      }
    }

    // ------------------------------------------------------------------
    // /feedback/{id} — bug reports + general feedback. Create-only from
    // signed-in clients; nobody reads/edits/deletes via the client (the owner
    // reviews submissions in the Firebase console). Shape + sizes are locked
    // down so the collection can't be abused as arbitrary storage.
    // ------------------------------------------------------------------
    match /feedback/{id} {
      allow read, update, delete: if false;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.type in ['bug', 'feedback']
                    && request.resource.data.message is string
                    && request.resource.data.message.size() >= 1
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.username is string
                    && request.resource.data.username.size() <= 30
                    && request.resource.data.route is string
                    && request.resource.data.route.size() <= 200
                    && request.resource.data.userAgent is string
                    && request.resource.data.userAgent.size() <= 500
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.keys().hasOnly(
                         ['uid', 'username', 'type', 'message', 'route', 'userAgent', 'createdAt']
                       );
    }

    // ------------------------------------------------------------------
    // /usernames/{name} — public read needed for username→email login
    // resolution. Create-only, length-capped to prevent storage abuse.
    // Delete is allowed only for the owner (D16 reversed): a username change
    // moves the sentinel by creating the new doc and releasing the old one in
    // one transaction. Update stays forbidden (renames go create+delete).
    // ------------------------------------------------------------------
    match /usernames/{name} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && name == name.lower()
                    && name.size() >= 3
                    && name.size() <= 30;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ------------------------------------------------------------------
    // /wagers/{wagerId} — Captain's Wager (WP-CW-C)
    // The public wager doc is readable by any authenticated user.
    // The /private/answer sub-doc and the submissions sub-collection are
    // gated: you must have your own submission before you can read either.
    // Scoring is client-authoritative (D-CW8 / R-W3); the rules enforce
    // the exact WagerSubmission shape (C-W1) and the one-shot invariant.
    // ------------------------------------------------------------------
    match /wagers/{wagerId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /private/{stateDoc} {
        // Gated: only readable after the user has a submission for this wager.
        allow read: if request.auth != null
                   && exists(/databases/$(database)/documents/wagers/$(wagerId)/submissions/$(request.auth.uid));
        allow write: if false;
      }

      match /submissions/{uid} {
        // One-shot create: auth uid must match the doc id, no prior submission
        // may exist, and the payload must carry exactly the C-W1 fields with
        // the correct types.
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && !exists(/databases/$(database)/documents/wagers/$(wagerId)/submissions/$(uid))
                      && request.resource.data.keys().hasOnly(['uid', 'guess', 'logError', 'score', 'submittedAt'])
                      && request.resource.data.uid == uid
                      && request.resource.data.guess is number
                      && request.resource.data.logError is number
                      && request.resource.data.score is number
                      && request.resource.data.submittedAt is timestamp;
        // GET and LIST split because Firestore evaluates LIST rules against
        // the QUERY, not per-doc. A rule that references the `{uid}` path
        // wildcard (like `request.auth.uid == uid`) can't be proven safe for
        // a collection scan — so it correctly works for own-doc gets but
        // denies the histogram LIST query. Split:
        //
        //   GET (single-doc read): own-doc always, or others if you have your
        //   own submission. Lets submitWager's duplicate-check `getDoc` work
        //   before the placeholder exists (the earlier `exists()`-only rule
        //   was the chicken-and-egg that broke first-time submitters).
        //
        //   LIST (collection scan for the histogram): uniform `exists()` check,
        //   no per-doc condition — Firestore CAN prove this safe.
        allow get:  if request.auth != null
                    && (
                      request.auth.uid == uid
                      || exists(/databases/$(database)/documents/wagers/$(wagerId)/submissions/$(request.auth.uid))
                    );
        allow list: if request.auth != null
                    && exists(/databases/$(database)/documents/wagers/$(wagerId)/submissions/$(request.auth.uid));
        // One-time score-patch: allowed only from the placeholder state where both
        // score and logError are still 0 (the sentinel values written by the placeholder
        // create in the two-step submit flow). Once either field is non-zero the gate
        // closes, making the patch idempotent. Only score and logError may change;
        // uid, guess, and submittedAt are immutable commitments.
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && resource.data.score == 0
                      && resource.data.logError == 0
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['score', 'logError'])
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.guess == resource.data.guess
                      && request.resource.data.submittedAt == resource.data.submittedAt
                      && request.resource.data.score is number
                      && request.resource.data.logError is number;
        allow delete: if false;
      }
    }

    // /users/{uid}/wagerStats/{statDoc} — owner read/write only.
    // Kept as a separate top-level match so it doesn't require amending the
    // existing /users/{uid} block; Firestore evaluates them independently.
    match /users/{uid}/wagerStats/{statDoc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
